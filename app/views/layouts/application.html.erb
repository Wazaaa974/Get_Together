<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Get Together — Trouvez où se retrouver" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Meta OG %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Get Together">
    <meta property="og:title" content="<%= content_for(:og_title) || "Get Together — Trouvez où se retrouver" %>">
    <meta property="og:description" content="<%= content_for(:og_description) || "Entrez vos villes de départ, Get Together trouve la destination européenne la moins chère pour tout le groupe." %>">
    <meta property="og:image" content="<%= content_for(:og_image) || asset_url("og-image.png") rescue root_url + "icon.png" %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:og_title) || "Get Together — Trouvez où se retrouver" %>">
    <meta name="twitter:description" content="<%= content_for(:og_description) || "Entrez vos villes de départ, Get Together trouve la destination européenne la moins chère pour tout le groupe." %>">

    <%# Mapbox token %>
    <% if ENV["MAPBOX_TOKEN"].present? %>
      <meta name="mapbox-token" content="<%= ENV["MAPBOX_TOKEN"] %>">
    <% end %>

    <%# Google Fonts — Fraunces + Inter + JetBrains Mono %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans text-gt-ink bg-gt-sand min-h-screen">

    <%# ── Navbar ── %>
    <% transparent_nav = content_for?(:transparent_nav) %>
    <nav class="fixed top-0 left-0 right-0 z-10 transition-colors <%= transparent_nav ? 'bg-transparent' : 'bg-gt-white border-b border-gt-line' %>">
      <div class="max-w-[1180px] mx-auto px-16 py-5 flex items-center justify-between">

        <%# Logo %>
        <%= link_to root_path, class: "flex items-center gap-2.5 no-underline" do %>
          <div class="w-8 h-8 rounded-full bg-gt-orange flex items-center justify-center text-white font-display italic text-[20px] leading-none flex-shrink-0">g</div>
          <span class="font-display text-gt-forest text-[22px] tracking-tight leading-none">Get Together</span>
        <% end %>

        <%# Breadcrumb (non-landing) %>
        <% if content_for?(:nav_crumb) %>
          <div class="flex items-center gap-2 ml-4">
            <span class="text-gt-muted text-sm">/</span>
            <span class="text-gt-ink-soft text-sm font-medium"><%= yield :nav_crumb %></span>
          </div>
        <% end %>

        <div class="flex-1"></div>

        <%# Nav links %>
        <div class="flex items-center gap-1">
          <% if transparent_nav %>
            <a href="#how-it-works" class="px-3 py-2 text-sm text-gt-ink-soft hover:text-gt-forest transition-colors">Comment ça marche</a>
          <% end %>
          <% if user_signed_in? %>
            <%= link_to "Mes trips", trips_path, class: "px-3 py-2 text-sm text-gt-ink-soft hover:text-gt-forest transition-colors" %>
            <span class="text-sm text-gt-muted hidden sm:inline px-2 truncate max-w-[140px]"><%= current_user.email %></span>
            <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "px-3 py-2 text-sm text-gt-ink-soft hover:text-gt-forest transition-colors" %>
          <% else %>
            <%= link_to "Se connecter", new_user_session_path, class: "px-3 py-2 text-sm text-gt-ink-soft hover:text-gt-forest transition-colors" %>
          <% end %>
          <%= link_to new_trip_path, class: "px-[18px] py-[10px] rounded-full bg-gt-orange text-white text-[13px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors ml-1" do %>
            Planifier un trip
          <% end %>
        </div>

      </div>
    </nav>

    <%= yield :full_width_hero %>

    <main class="<%= content_for?(:full_width_hero) ? '' : 'max-w-[1180px] mx-auto px-8 pb-20 pt-[81px]' %>">

      <% if notice.present? %>
        <div class="<%= content_for?(:full_width_hero) ? 'max-w-[1180px] mx-auto px-8' : '' %> mb-5">
          <div class="bg-green-50 border border-green-200 text-green-800 text-sm px-4 py-3 rounded-[8px] flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <%= notice %>
          </div>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="<%= content_for?(:full_width_hero) ? 'max-w-[1180px] mx-auto px-8' : '' %> mb-5">
          <div class="bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3 rounded-[8px] flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <%= alert %>
          </div>
        </div>
      <% end %>

      <%= yield %>

    </main>

  </body>
</html>
