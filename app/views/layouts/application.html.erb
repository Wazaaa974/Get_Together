<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Get Together — Trouvez où se retrouver" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Meta OG — prévisualisation WhatsApp / Slack / Twitter %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Get Together">
    <meta property="og:title" content="<%= content_for(:og_title) || "Get Together — Trouvez où se retrouver" %>">
    <meta property="og:description" content="<%= content_for(:og_description) || "Entrez vos villes de départ, Get Together trouve la destination européenne la moins chère pour tout le groupe." %>">
    <meta property="og:image" content="<%= content_for(:og_image) || asset_url("og-image.png") rescue root_url + "icon.png" %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:og_title) || "Get Together — Trouvez où se retrouver" %>">
    <meta name="twitter:description" content="<%= content_for(:og_description) || "Entrez vos villes de départ, Get Together trouve la destination européenne la moins chère pour tout le groupe." %>">

    <%# Mapbox token accessible aux controllers Stimulus %>
    <% if ENV["MAPBOX_TOKEN"].present? %>
      <meta name="mapbox-token" content="<%= ENV["MAPBOX_TOKEN"] %>">
    <% end %>

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gt-sand min-h-screen">

    <nav class="bg-gt-white border-b border-gray-100 fixed top-0 left-0 right-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">

        <%# Logo %>
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <div class="w-7 h-7 bg-gt-orange rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5" fill="white" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <span class="font-medium text-gt-forest text-sm">Get Together</span>
        <% end %>

        <%# Nav links %>
        <div class="flex items-center gap-2">
          <% if user_signed_in? %>
            <%= link_to "Mes trips", trips_path,
                class: "text-sm text-gray-500 hover:bg-gray-100 rounded-[8px] px-3 py-1.5 transition-colors" %>
            <span class="text-sm text-gray-400 hidden sm:inline truncate max-w-[160px]"><%= current_user.email %></span>
            <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete },
                class: "text-sm text-gray-500 hover:bg-gray-100 rounded-[8px] px-3 py-1.5 transition-colors" %>
          <% else %>
            <%= link_to "Se connecter", new_user_session_path,
                class: "text-sm text-gray-500 hover:bg-gray-100 rounded-[8px] px-3 py-1.5 transition-colors" %>
            <%= link_to "Créer un compte", new_user_registration_path,
                class: "text-sm font-medium bg-gt-orange text-white rounded-[8px] px-4 py-2 hover:bg-gt-orange-dark transition-colors" %>
          <% end %>
        </div>

      </div>
    </nav>

    <main class="max-w-5xl mx-auto mt-[73px] px-6 py-8 pb-20 min-h-screen">

      <% if notice.present? %>
        <div class="mb-5 bg-green-50 border border-green-200 text-green-800 text-sm px-4 py-3 rounded-[8px] flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-5 bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3 rounded-[8px] flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>

    </main>

  </body>
</html>
