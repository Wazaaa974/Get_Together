<%= turbo_frame_tag dom_id(@participant) do %>
  <li class="px-6 py-3.5 bg-indigo-50">
    <%= form_with model: [@trip, @participant], class: "flex gap-2 flex-wrap items-center" do |f| %>
      <%= f.text_field :name, placeholder: "Prénom",
          class: "flex-1 min-w-24 border border-indigo-300 bg-white rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <%= f.text_field :origin_city, placeholder: "Ville",
          class: "flex-1 min-w-28 border border-indigo-300 bg-white rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <%= f.text_field :origin_airport_code, placeholder: "IATA",
          class: "w-24 border border-indigo-300 bg-white rounded-lg px-3 py-1.5 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <%= f.submit "Sauvegarder",
          class: "bg-indigo-600 text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <%= link_to "Annuler", trip_path(@trip),
          class: "text-sm text-gray-500 hover:text-gray-700 px-2 py-1.5",
          data: { turbo_frame: dom_id(@participant) } %>
    <% end %>
  </li>
<% end %>
