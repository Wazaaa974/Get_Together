<%
  top3   = @results.first(3)
  best   = top3.first
  others = @results.drop(3)

  _best_city_name = best[:city].city_name
  _best_price_eur = (best[:total_cents] / 100.0).round
  content_for :og_title, "Le groupe se retrouve à #{_best_city_name} — #{_best_price_eur} €"
  content_for :og_description, "Voici la destination la moins chère pour « #{@trip.title} ». Vote pour la tienne."
  content_for :og_image, trip_og_image_url(@trip.share_token) if @trip.share_token.present?
  content_for :nav_crumb, "#{@trip.title} / Résultats"

  city_photos = {
    "barcelone"   => "photo-1539037116277-4db20889f2d4",
    "barcelona"   => "photo-1539037116277-4db20889f2d4",
    "lisbonne"    => "photo-1548707309-dcebeab9ea9b",
    "lisbon"      => "photo-1548707309-dcebeab9ea9b",
    "lisboa"      => "photo-1548707309-dcebeab9ea9b",
    "dublin"      => "photo-1513635269975-59663e0ac1ad",
    "bruxelles"   => "photo-1559113202-c916b8e44373",
    "brussels"    => "photo-1559113202-c916b8e44373",
    "amsterdam"   => "photo-1534351590666-13e3e96b5017",
    "berlin"      => "photo-1560969184-10fe8719e047",
    "paris"       => "photo-1502602898657-3e91760cbb34",
    "rome"        => "photo-1552832230-c0197dd311b5",
    "roma"        => "photo-1552832230-c0197dd311b5",
    "madrid"      => "photo-1583422409516-2895a77efded",
    "vienne"      => "photo-1573599852326-2d4da0bbe613",
    "vienna"      => "photo-1573599852326-2d4da0bbe613",
    "prague"      => "photo-1592906209472-a36b1f3782ef",
    "budapest"    => "photo-1541343672885-9be56236302a",
    "copenhague"  => "photo-1513622470522-26c3c8a854bc",
    "copenhagen"  => "photo-1513622470522-26c3c8a854bc",
    "stockholm"   => "photo-1509356843151-3e7d96241e11",
    "athènes"     => "photo-1603565816030-6b389eeb23cb",
    "athens"      => "photo-1603565816030-6b389eeb23cb",
    "zurich"      => "photo-1515488764276-beab7607c1e6",
    "zürich"      => "photo-1515488764276-beab7607c1e6",
    "milan"       => "photo-1610016302534-6f67f1c968d8",
    "porto"       => "photo-1562183241-840b8af0721e",
    "nice"        => "photo-1491557345352-5929e343eb89",
    "malaga"      => "photo-1555881400-74d7acaacd8b",
  }
  winner_photo_id = city_photos[best[:city].city_name.downcase.unicode_normalize(:nfd).gsub(/\p{Mn}/, "").strip] ||
                    city_photos[best[:city].city_name.downcase.strip]

  participants_data = @trip.participants.map { |p| { name: p.name, city: p.origin_city } }

  results_data = @results.map { |r|
    coords       = PopularDestinations.coordinates_for(r[:city].airport_code)
    max_duration = r[:quotes].map(&:duration_minutes).compact.max
    {
      city_name:    r[:city].city_name,
      country_code: r[:city].country_code,
      total_cents:  r[:total_cents],
      airport_code: r[:city].airport_code,
      max_duration: max_duration,
      lat: coords ? coords[0] : nil,
      lng: coords ? coords[1] : nil,
      quotes: r[:quotes].map { |q| {
        name:               q.participant.name,
        city:               q.participant.origin_city,
        origin_iata:        q.participant.origin_airport_code.presence,
        price:              q.price_euros.round,
        duration:           q.duration_minutes,
        is_local:           q.price_cents == 0,
        is_round_trip:      q.is_round_trip,
        airline:            q.airline_name,
        departure_at:       q.departure_at&.strftime("%H:%M"),
        arrival_at:         q.arrival_at&.strftime("%H:%M"),
        departure_date:     q.departure_at&.strftime("%d %b"),
        departure_date_iso: (q.departure_at&.to_date || @trip.start_date)&.strftime("%Y-%m-%d"),
        next_day:           q.departure_at.present? && q.arrival_at.present? && q.arrival_at.to_date > q.departure_at.to_date
      }}
    }
  }

  mapbox_token = ENV["MAPBOX_TOKEN"]
  is_owner     = user_signed_in? && current_user == @trip.user

  avg_price   = best[:total_cents] > 0 ? (best[:total_cents] / 100.0 / [@trip.participants.count, 1].max).round : 0
  max_dur     = best[:quotes].map(&:duration_minutes).compact.max
  diff_vs_2   = top3[1] ? ((top3[1][:total_cents] - best[:total_cents]) / 100.0).ceil : nil

  # Build best GFlights URL for the winner city
  best_gf_url = begin
    first_q = best[:quotes].reject { |q| q.price_cents == 0 }.first
    if first_q
      origin_iata = first_q.participant.origin_airport_code.presence
      dest_iata   = best[:city].airport_code.presence
      flight_date = first_q.departure_at&.to_date || @trip.start_date
      if origin_iata && dest_iata && flight_date
        outbound = "#{origin_iata}.#{dest_iata}.#{flight_date.strftime('%Y-%m-%d')}"
        "https://www.google.com/travel/flights#flt=#{outbound};c:EUR;e:1;sd:1;t:f"
      end
    end
  rescue nil
  end
  best_gf_url ||= "https://www.google.com/travel/flights?q=#{CGI.escape(best[:city].city_name)}"
%>

<%= content_for :head do %>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js"></script>
<% end %>

<div class="max-w-[1180px] mx-auto px-4 sm:px-6 lg:px-8 pt-[73px] lg:pt-[81px] pb-20">

  <%# ── WinnerCard ── %>
  <div class="rounded-[24px] relative overflow-hidden mb-5 p-6 sm:p-8 lg:p-12" style="background: linear-gradient(150deg, #1A1F2E 0%, #2D4A3E 65%, #4A7A65 100%);">

    <%# City photo — blended from the right %>
    <div id="winner-photo-layer" class="absolute inset-0 pointer-events-none" style="
      background-image: <%= winner_photo_id ? "url('https://images.unsplash.com/#{winner_photo_id}?w=1400&h=700&fit=crop&crop=center&q=80')" : 'none' %>;
      background-size: cover;
      background-position: center right;
      opacity: <%= winner_photo_id ? '0.22' : '0' %>;
      mix-blend-mode: overlay;
      -webkit-mask-image: linear-gradient(to right, transparent 20%, black 70%);
      mask-image: linear-gradient(to right, transparent 20%, black 70%);
    "></div>

    <%# Orange glow top-right %>
    <div class="absolute right-[-80px] top-[-80px] w-[320px] h-[320px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(232,99,42,0.4) 0%, transparent 65%);"></div>

    <%# Stamp — top right (hidden on mobile to save space) %>
    <div class="absolute right-6 top-6 sm:right-10 sm:top-10 hidden sm:block" style="transform: rotate(8deg);" aria-hidden="true">
      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-dashed border-gt-orange text-gt-orange rounded font-mono text-[10px] font-medium tracking-[0.12em] uppercase bg-transparent">Cheapest for the group</div>
    </div>

    <div class="relative">
      <%# Dark chips %>
      <div class="flex items-center gap-2.5 mb-5 flex-wrap">
        <span id="winner-rank-chip" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#2b2d35] text-white text-xs font-medium">★ Best fit</span>
      </div>

      <%# Meet in kicker %>
      <div class="font-mono text-[12px] tracking-[0.14em] uppercase text-white/70 mb-1">Meet in</div>

      <%# City name — responsive %>
      <h1 id="winner-city-name" class="font-display font-normal text-white leading-[0.92] tracking-[-0.03em] mb-2 text-[56px] sm:text-[88px] lg:text-[120px] xl:text-[140px]">
        <%= best[:city].city_name %><em class="italic text-gt-orange not-italic">.</em>
      </h1>

      <%# Country · IATA italic subtitle %>
      <div id="winner-subtitle" class="font-display italic text-[18px] sm:text-[22px] text-white/75 mb-6 sm:mb-8">
        <%= best[:city].country_code %> · <%= best[:city].airport_code %>
      </div>

      <%# Stats row %>
      <div class="flex gap-6 sm:gap-9 lg:gap-12 mb-6 sm:mb-8 flex-wrap">
        <div>
          <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-white/55">Total groupe</div>
          <div id="winner-total-val" class="font-display italic text-[32px] sm:text-[40px] lg:text-[44px] text-white leading-none mt-1">€<%= (best[:total_cents] / 100.0).round %></div>
        </div>
        <div>
          <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-white/55">Moy. par personne</div>
          <div id="winner-avg-val" class="font-display text-[22px] sm:text-[26px] lg:text-[28px] text-white leading-none mt-1">€<%= avg_price %></div>
        </div>
        <div id="winner-dur-block" class="<%= (max_dur.present? && max_dur > 0) ? '' : 'hidden' %>">
          <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-white/55">Vol le plus long</div>
          <div id="winner-dur-val" class="font-display text-[22px] sm:text-[26px] lg:text-[28px] text-white leading-none mt-1"><%= max_dur.present? && max_dur > 0 ? "#{max_dur / 60}h#{max_dur % 60}m" : "" %></div>
        </div>
        <div id="winner-diff-block" class="<%= diff_vs_2 ? '' : 'hidden' %>">
          <div id="winner-diff-label" class="font-mono text-[10px] tracking-[0.12em] uppercase text-white/55">Moins cher que #2</div>
          <div id="winner-diff-val" class="font-display text-[22px] sm:text-[26px] lg:text-[28px] text-white leading-none mt-1"><%= diff_vs_2 ? "−€#{diff_vs_2}" : "" %></div>
        </div>
      </div>

      <%# CTAs %>
      <div class="flex items-center gap-3 flex-wrap">
        <%= link_to best_gf_url, target: "_blank", rel: "noopener", id: "winner-gf-link",
            class: "px-[22px] py-[14px] rounded-full bg-gt-orange text-white text-[15px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors inline-flex items-center gap-2" do %>
          Réserver sur Google Flights →
        <% end %>
        <% if @trip.share_token.present? %>
          <button type="button"
            id="share-results-btn"
            data-share-url="<%= shared_trip_results_url(@trip.share_token) %>"
            data-share-text="<%= "#{@trip.title} → #{best[:city].city_name} pour #{(best[:total_cents] / 100.0).round}€ total (#{avg_price}€/pers). Trouvé par Get Together 🗺️" %>"
            data-share-title="<%= "#{@trip.title} — Get Together" %>"
            data-trip-id="<%= @trip.id %>"
            onclick="shareResults(this)"
            class="px-[18px] py-3 rounded-full border border-white/25 text-white text-sm font-medium hover:bg-white/10 transition-colors inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
            <span id="share-btn-label">Partager les résultats</span>
          </button>
        <% end %>
      </div>

      <%= render "trips/booking_cta", trip: @trip, city_name: best[:city].city_name, airport_code: best[:city].airport_code %>
    </div>
  </div>

  <%# ── Mapbox map (compact) ── %>
  <div data-controller="map-toggle" class="mb-5">
    <div class="flex items-center justify-between mb-2 sm:hidden">
      <span class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted">Carte interactive</span>
      <button data-map-toggle-target="button" data-action="click->map-toggle#toggle"
              class="text-[12px] text-gt-orange border border-gt-orange/30 px-3 py-1.5 rounded-full font-medium hover:bg-gt-orange-light transition-colors">
        Voir la carte
      </button>
    </div>
    <div data-map-toggle-target="map" class="bg-gt-white border border-gt-line rounded-[18px] overflow-hidden">
      <div id="map" class="w-full h-56 sm:h-72"
           data-controller="map"
           data-map-token-value="<%= mapbox_token %>"
           data-map-participants-value="<%= participants_data.to_json %>"
           data-map-results-value="<%= results_data.to_json %>"
           data-map-selected-value="0">
      </div>
    </div>
  </div>

  <%# ── Filter pills ── %>
  <div class="flex items-center justify-between flex-wrap gap-3 mb-5"
       data-controller="results-filter"
       data-results-filter-data-value="<%= results_data.to_json %>">
    <div class="flex items-center gap-1 bg-gt-sand-dark rounded-[8px] p-1">
      <button type="button" data-results-filter-target="pill" data-value="total_asc"
              data-action="click->results-filter#applyPill"
              data-participant-name="<%= @trip.participants.first&.name %>"
              class="px-3 py-1.5 rounded-[6px] text-[13px] font-medium transition-all bg-gt-white text-gt-forest">
        Prix total
      </button>
      <button type="button" data-results-filter-target="pill" data-value="duration_asc"
              data-action="click->results-filter#applyPill"
              class="px-3 py-1.5 rounded-[6px] text-[13px] font-medium transition-all text-gt-muted hover:text-gt-forest">
        Durée de vol
      </button>
      <% if @trip.participants.first %>
        <button type="button" data-results-filter-target="pill" data-value="cheapest_for_me"
                data-action="click->results-filter#applyPill"
                class="px-3 py-1.5 rounded-[6px] text-[13px] font-medium transition-all text-gt-muted hover:text-gt-forest hidden sm:block">
          Mon prix
        </button>
      <% end %>
    </div>
    <span class="font-mono text-[11px] tracking-[0.08em] text-gt-muted uppercase"><%= @results.count %> destinations évaluées</span>
  </div>

  <%# ── Main grid: breakdown left + (runners-up + vote) right ── %>
  <div class="grid gap-5 grid-cols-1 lg:[grid-template-columns:1.3fr_1fr]" id="top3-cards"
       data-results-filter-target="cards">

    <%# ── Fare Breakdown Panel ── %>
    <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]" id="detail-section">
      <div class="flex items-baseline justify-between mb-1">
        <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted">Détail des vols</div>
        <span class="text-[13px] text-gt-muted" id="detail-title">→ <%= best[:city].city_name %> · <%= @trip.start_date&.strftime("%d %b") %></span>
      </div>
      <ul class="mt-3" id="detail-list">
        <% best[:quotes].sort_by(&:price_cents).each_with_index do |quote, qi| %>
          <%
            tones_list = ['ember','forest','sky','plum','sand']
            tone = tones_list[qi % tones_list.length]
            tone_bg = { 'ember' => 'bg-gt-orange-light', 'forest' => 'bg-[#DDE7E1]', 'sky' => 'bg-[#DCE8F1]', 'plum' => 'bg-[#EADCF0]', 'sand' => 'bg-gt-sand-dark' }[tone]
            tone_fg = { 'ember' => 'text-gt-orange-dark', 'forest' => 'text-gt-forest', 'sky' => 'text-[#3A6B92]', 'plum' => 'text-[#7A3F8F]', 'sand' => 'text-gt-ink-soft' }[tone]

            origin_iata = quote.participant.origin_airport_code.presence
            dest_iata   = best[:city].airport_code.presence
            flight_date = quote.departure_at&.to_date || @trip.start_date
            if origin_iata && dest_iata && flight_date
              outbound = "#{origin_iata}.#{dest_iata}.#{flight_date.strftime('%Y-%m-%d')}"
              return_leg = (quote.is_round_trip && @trip.end_date) ? "*#{dest_iata}.#{origin_iata}.#{@trip.end_date.strftime('%Y-%m-%d')}" : ""
              gf_url = "https://www.google.com/travel/flights#flt=#{outbound}#{return_leg};c:EUR;e:1;sd:1;t:f"
            else
              gf_url = "https://www.google.com/travel/flights?q=#{CGI.escape("#{quote.participant.origin_city} to #{best[:city].city_name}")}"
            end
          %>
          <li class="grid items-center gap-2 sm:gap-3 py-3 sm:py-3.5 <%= qi < best[:quotes].count - 1 ? 'border-b border-dashed border-gt-line' : '' %> [grid-template-columns:40px_1fr_auto] sm:[grid-template-columns:44px_1.1fr_1fr_70px_70px]">
            <div class="w-9 h-9 rounded-full <%= tone_bg %> <%= tone_fg %> flex items-center justify-center text-[13px] font-semibold border-2 border-gt-white flex-shrink-0">
              <%= quote.participant.name[0..1].upcase %>
            </div>
            <div class="min-w-0">
              <div class="text-[14px] font-medium text-gt-ink truncate"><%= quote.participant.name %></div>
              <div class="font-mono text-[11px] text-gt-muted tracking-[0.04em] truncate"><%= origin_iata || quote.participant.origin_city %> → <%= dest_iata || best[:city].city_name %></div>
            </div>
            <div class="hidden sm:block text-[13px] text-gt-ink-soft truncate"><%= quote.participant.origin_city %></div>
            <div class="hidden sm:block font-mono text-[12px] text-gt-muted text-right">
              <% if quote.duration_minutes.present? && quote.duration_minutes > 0 %>
                <%= quote.duration_minutes / 60 %>h<%= quote.duration_minutes % 60 %>m
              <% end %>
            </div>
            <div class="text-right flex items-center justify-end gap-2">
              <% if quote.price_cents == 0 %>
                <span class="font-display italic text-[18px] text-gt-forest-light">Local</span>
              <% else %>
                <div>
                  <div class="font-display italic text-[22px] text-gt-orange leading-none">€<%= quote.price_euros.round %></div>
                  <% if quote.is_round_trip %>
                    <div class="font-mono text-[9px] text-gt-muted tracking-[0.06em]">A/R</div>
                  <% end %>
                </div>
                <%= link_to gf_url, target: "_blank", rel: "noopener",
                    class: "text-gt-muted hover:text-gt-orange transition-colors p-1",
                    title: "Google Flights" do %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                <% end %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
      <%# Total row %>
      <div class="border-t border-gt-line mt-2 pt-4 flex justify-between items-baseline">
        <span class="font-mono text-[11px] tracking-[0.12em] uppercase text-gt-muted">Total groupe</span>
        <span class="font-display italic text-[36px] text-gt-forest tracking-[-0.02em]">€<%= (best[:total_cents] / 100.0).round %></span>
      </div>
    </div>

    <%# ── Right column: runners-up + vote ── %>
    <div class="flex flex-col gap-5">

      <%# Classement complet — toutes les destinations cliquables %>
      <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]">
        <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted mb-3.5">Classement complet</div>
        <% @results.each_with_index do |result, i| %>
          <%
            diff = i == 0 ? nil : ((result[:total_cents] - best[:total_cents]) / 100.0).ceil
          %>
          <div data-result-idx="<%= i %>"
               onclick="selectDestination(<%= i %>)"
               class="flex items-center gap-2.5 py-2.5 px-2 -mx-2 rounded-[10px] cursor-pointer transition-colors <%= i < @results.count - 1 ? 'border-b border-dashed border-gt-line' : '' %> <%= i == 0 ? 'bg-gt-sand-dark' : 'hover:bg-gt-sand' %>">
            <span class="font-mono text-[11px] text-gt-muted w-5 flex-shrink-0">#<%= i + 1 %></span>
            <span class="flex-1 text-[14px] text-gt-ink font-medium truncate"><%= result[:city].city_name %></span>
            <% if diff %>
              <span class="font-mono text-[11px] text-gt-orange-dark flex-shrink-0">+€<%= diff %></span>
            <% else %>
              <span class="font-mono text-[10px] text-gt-muted flex-shrink-0 tracking-[0.06em]">BEST</span>
            <% end %>
            <span class="font-display italic text-[18px] text-gt-forest min-w-[48px] text-right flex-shrink-0">€<%= (result[:total_cents] / 100.0).round %></span>
          </div>
        <% end %>
      </div>

      <%# Vote panel — uses existing Turbo Stream replacement pattern %>
      <%= render "votes/section", trip: @trip, error: nil %>

    </div>

  </div><%# end grid %>

  <%# ── Actions ── %>
  <div class="flex flex-wrap gap-3 mt-6">
    <% if is_owner %>
      <%= link_to "← Retour au trip", trip_path(@trip),
          class: "px-[18px] py-3 rounded-full border border-gt-line text-gt-ink-soft text-sm font-medium hover:border-gt-forest/30 hover:text-gt-forest transition-colors" %>
      <%= button_to "Actualiser les prix", optimize_trip_path(@trip), method: :post,
          class: "px-[22px] py-[14px] rounded-full bg-gt-orange text-white text-[15px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors" %>
    <% end %>
    <% if @trip.last_optimized_at.present? %>
      <span class="flex items-center gap-1.5 text-[12px] text-gt-muted self-center">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Calculé il y a <%= time_ago_in_words(@trip.last_optimized_at) %>
      </span>
    <% end %>
  </div>

</div>

<script>
  async function shareResults(btn) {
    const url   = btn.dataset.shareUrl;
    const text  = btn.dataset.shareText;
    const title = btn.dataset.shareTitle;
    const label = document.getElementById('share-btn-label');

    if (navigator.share) {
      try {
        await navigator.share({ title, text, url });
        return;
      } catch (e) {
        if (e.name === 'AbortError') return;
      }
    }

    try {
      await navigator.clipboard.writeText(url);
      label.textContent = '✓ Lien copié !';
      btn.classList.add('border-white/60', 'bg-white/10');
      setTimeout(() => {
        label.textContent = 'Partager les résultats';
        btn.classList.remove('border-white/60', 'bg-white/10');
      }, 2500);
      fetch('/t', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
        body: JSON.stringify({ event: 'share_link_copied', trip_id: btn.dataset.tripId })
      });
    } catch (e) {
      prompt('Copiez ce lien :', url);
    }
  }

  const allResults          = <%= raw results_data.to_json %>;
  const tripReturnDate      = <%= raw @trip.end_date&.strftime("%Y-%m-%d").to_json %>;
  const tripParticipants    = <%= @trip.participants.count %>;

  const TONE_BG = ['bg-gt-orange-light','bg-[#DDE7E1]','bg-[#DCE8F1]','bg-[#EADCF0]','bg-gt-sand-dark'];
  const TONE_FG = ['text-gt-orange-dark','text-gt-forest','text-[#3A6B92]','text-[#7A3F8F]','text-gt-ink-soft'];

  const CITY_PHOTOS = {
    "barcelone":"photo-1539037116277-4db20889f2d4","barcelona":"photo-1539037116277-4db20889f2d4",
    "lisbonne":"photo-1548707309-dcebeab9ea9b","lisbon":"photo-1548707309-dcebeab9ea9b","lisboa":"photo-1548707309-dcebeab9ea9b",
    "dublin":"photo-1513635269975-59663e0ac1ad",
    "bruxelles":"photo-1559113202-c916b8e44373","brussels":"photo-1559113202-c916b8e44373",
    "amsterdam":"photo-1534351590666-13e3e96b5017",
    "berlin":"photo-1560969184-10fe8719e047",
    "paris":"photo-1502602898657-3e91760cbb34",
    "rome":"photo-1552832230-c0197dd311b5","roma":"photo-1552832230-c0197dd311b5",
    "madrid":"photo-1583422409516-2895a77efded",
    "vienne":"photo-1573599852326-2d4da0bbe613","vienna":"photo-1573599852326-2d4da0bbe613",
    "prague":"photo-1592906209472-a36b1f3782ef",
    "budapest":"photo-1541343672885-9be56236302a",
    "copenhague":"photo-1513622470522-26c3c8a854bc","copenhagen":"photo-1513622470522-26c3c8a854bc",
    "stockholm":"photo-1509356843151-3e7d96241e11",
    "athenes":"photo-1603565816030-6b389eeb23cb","athens":"photo-1603565816030-6b389eeb23cb",
    "zurich":"photo-1515488764276-beab7607c1e6",
    "milan":"photo-1610016302534-6f67f1c968d8",
    "porto":"photo-1562183241-840b8af0721e",
    "nice":"photo-1491557345352-5929e343eb89",
    "malaga":"photo-1555881400-74d7acaacd8b",
  };

  function normalize(str) {
    return str.toLowerCase().normalize('NFD').replace(/\p{M}/gu, '').trim();
  }

  function getCityPhotoUrl(cityName) {
    const key = normalize(cityName);
    const id  = CITY_PHOTOS[key] || CITY_PHOTOS[cityName.toLowerCase().trim()];
    return id ? `https://images.unsplash.com/${id}?w=1400&h=700&fit=crop&crop=center&q=80` : null;
  }

  function buildGFlightsUrl(originIata, destIata, departDate, returnDate) {
    if (originIata && destIata && departDate) {
      const outbound  = `${originIata}.${destIata}.${departDate}`;
      const returnLeg = returnDate ? `*${destIata}.${originIata}.${returnDate}` : '';
      return `https://www.google.com/travel/flights#flt=${outbound}${returnLeg};c:EUR;e:1;sd:1;t:f`;
    }
    return null;
  }

  function selectDestination(index) {
    index = parseInt(index, 10);
    const result = allResults[index];
    if (!result) return;

    // ── 1. Update winner card photo ──
    const photoLayer = document.getElementById('winner-photo-layer');
    if (photoLayer) {
      const url = getCityPhotoUrl(result.city_name);
      photoLayer.style.backgroundImage = url ? `url('${url}')` : 'none';
      photoLayer.style.opacity = url ? '0.22' : '0';
    }

    // ── 2. Update winner card text ──
    document.getElementById('winner-rank-chip').textContent =
      index === 0 ? '★ Best fit' : `#${index + 1}`;

    document.getElementById('winner-city-name').innerHTML =
      `${result.city_name}<em class="italic text-gt-orange not-italic">.</em>`;

    document.getElementById('winner-subtitle').textContent =
      `${result.country_code} · ${result.airport_code}`;

    // ── 3. Update stats ──
    const totalEur = Math.round(result.total_cents / 100);
    const avgEur   = tripParticipants > 0 ? Math.round(totalEur / tripParticipants) : totalEur;
    document.getElementById('winner-total-val').textContent = `€${totalEur}`;
    document.getElementById('winner-avg-val').textContent   = `€${avgEur}`;

    const durBlock = document.getElementById('winner-dur-block');
    if (result.max_duration && result.max_duration > 0) {
      durBlock.classList.remove('hidden');
      document.getElementById('winner-dur-val').textContent =
        `${Math.floor(result.max_duration / 60)}h${result.max_duration % 60}m`;
    } else {
      durBlock.classList.add('hidden');
    }

    const diffBlock   = document.getElementById('winner-diff-block');
    const nextResult  = allResults[index + 1];
    if (nextResult) {
      diffBlock.classList.remove('hidden');
      const diffEur = Math.ceil((nextResult.total_cents - result.total_cents) / 100);
      document.getElementById('winner-diff-label').textContent = `Moins cher que #${index + 2}`;
      document.getElementById('winner-diff-val').textContent   = `−€${diffEur}`;
    } else {
      diffBlock.classList.add('hidden');
    }

    // ── 4. Update Google Flights CTA ──
    const gfLink = document.getElementById('winner-gf-link');
    if (gfLink) {
      const q = result.quotes.find(q => q.origin_iata && !q.is_local);
      if (q) {
        const url = buildGFlightsUrl(q.origin_iata, result.airport_code, q.departure_date_iso,
                      q.is_round_trip ? tripReturnDate : null);
        if (url) gfLink.href = url;
      }
    }

    // ── 5. Highlight selected row in classement panel ──
    document.querySelectorAll('[data-result-idx]').forEach(el => {
      const idx = parseInt(el.dataset.resultIdx, 10);
      el.classList.toggle('bg-gt-sand-dark', idx === index);
      el.classList.toggle('hover:bg-gt-sand', idx !== index);
    });

    // ── 6. Update fare breakdown table ──
    document.getElementById('detail-title').textContent = `→ ${result.city_name}`;
    const list = document.getElementById('detail-list');
    list.innerHTML = result.quotes.map((q, qi) => {
      const bg = TONE_BG[qi % TONE_BG.length];
      const fg = TONE_FG[qi % TONE_FG.length];
      const retDate = q.is_round_trip ? tripReturnDate : null;
      const gfUrl = buildGFlightsUrl(q.origin_iata, result.airport_code, q.departure_date_iso, retDate)
        || `https://www.google.com/travel/flights?q=${encodeURIComponent(q.city + ' to ' + result.city_name)}`;
      const price = q.is_local
        ? `<span class="font-display italic text-[18px] text-gt-forest-light">Local</span>`
        : `<div><div class="font-display italic text-[22px] text-gt-orange leading-none">€${q.price}</div>${q.is_round_trip ? '<div class="font-mono text-[9px] text-gt-muted">A/R</div>' : ''}</div>
           <a href="${gfUrl}" target="_blank" rel="noopener" class="text-gt-muted hover:text-gt-orange transition-colors p-1">
             <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
           </a>`;
      const dur = q.duration ? `${Math.floor(q.duration/60)}h${q.duration%60}m` : '';
      return `
        <li class="grid items-center gap-2 sm:gap-3 py-3 sm:py-3.5 ${qi < result.quotes.length - 1 ? 'border-b border-dashed border-gt-line' : ''} [grid-template-columns:40px_1fr_auto] sm:[grid-template-columns:44px_1.1fr_1fr_70px_70px]">
          <div class="w-9 h-9 rounded-full ${bg} ${fg} flex items-center justify-center text-[13px] font-semibold border-2 border-gt-white flex-shrink-0">
            ${q.name.substring(0,2).toUpperCase()}
          </div>
          <div class="min-w-0">
            <div class="text-[14px] font-medium text-gt-ink truncate">${q.name}</div>
            <div class="font-mono text-[11px] text-gt-muted truncate">${q.origin_iata || q.city} → ${result.airport_code}</div>
          </div>
          <div class="hidden sm:block text-[13px] text-gt-ink-soft truncate">${q.city}</div>
          <div class="hidden sm:block font-mono text-[12px] text-gt-muted text-right">${dur}</div>
          <div class="text-right flex items-center justify-end gap-2">${price}</div>
        </li>`;
    }).join('');

    const totalEl = list.closest('#detail-section').querySelector('#winner-total-val, .breakdown-total');
    if (totalEl && totalEl.id !== 'winner-total-val') totalEl.textContent = `€${Math.round(result.total_cents / 100)}`;
    const brkTotal = list.closest('#detail-section').querySelector('.font-display.italic.text-gt-forest');
    if (brkTotal) brkTotal.textContent = `€${Math.round(result.total_cents / 100)}`;

    // ── 7. Map sync ──
    const mapEl = document.getElementById('map');
    if (mapEl?._stimulus_controller) mapEl._stimulus_controller.selectDestination(index);
    if (mapEl) mapEl.dataset.mapSelectedValue = index;
  }
</script>
