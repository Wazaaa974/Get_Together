<%# locals: (trip:, city_name:, airport_code:) %>

<div class="mt-5 pt-5 border-t border-white/10">
  <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-white/50 mb-3">Réserver pour ce trip</div>
  <div class="flex flex-wrap gap-2">

    <%# Flights — Aviasales %>
    <%= link_to booking_out_path(type: "flight", trip_id: trip.id, destination: city_name, destination_iata: airport_code),
        target: "_blank", rel: "noopener sponsored",
        class: "inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-white text-[13px] font-medium transition-colors" do %>
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
      Vols
    <% end %>

    <%# Hotels — Booking.com via tp.media %>
    <%= link_to booking_out_path(type: "hotel", trip_id: trip.id, destination: city_name, destination_iata: airport_code),
        target: "_blank", rel: "noopener sponsored",
        class: "inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-white text-[13px] font-medium transition-colors" do %>
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" points="9 22 9 12 15 12 15 22"/>
      </svg>
      Hôtels
    <% end %>

    <%# Trains — Omio via tp.media %>
    <%= link_to booking_out_path(type: "train", trip_id: trip.id, destination: city_name, destination_iata: airport_code),
        target: "_blank", rel: "noopener sponsored",
        class: "inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-white text-[13px] font-medium transition-colors" do %>
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <rect x="3" y="4" width="18" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 4v4M16 4v4M3 12h18M7 18l-2 2M17 18l2 2"/>
      </svg>
      Trains
    <% end %>

  </div>
</div>
