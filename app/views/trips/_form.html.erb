<%= form_with(model: trip, class: "space-y-5") do |f| %>
  <% if trip.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 mb-1">Impossible de sauvegarder :</p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% trip.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Titre du trip", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_field :title,
        class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition",
        placeholder: "Ex : Weekend à Dublin" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, "Date de départ", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.date_field :start_date,
          class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
    </div>
    <div>
      <%= f.label :end_date, "Date de retour", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.date_field :end_date,
          class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
    </div>
  </div>

  <% if trip.persisted? %>
    <div>
      <%= f.label :status, "Statut", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.select :status,
          [["Brouillon", "draft"], ["Actif", "active"], ["Terminé", "completed"]],
          { selected: trip.status.presence || "draft" },
          class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition bg-white" %>
    </div>
  <% else %>
    <%= f.hidden_field :status, value: "draft" %>
  <% end %>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit trip.persisted? ? "Enregistrer" : "Créer le voyage",
        class: "bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer",
        data: { disable_with: trip.persisted? ? "Enregistrement…" : "Création…" } %>
    <%= link_to "Annuler", trip.persisted? ? trip_path(trip) : trips_path,
        class: "text-sm text-gray-500 hover:text-gray-700 px-3 py-2.5 transition-colors" %>
  </div>
<% end %>
