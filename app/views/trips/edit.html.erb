<div class="w-full max-w-lg mx-auto">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-6">
    <%= link_to "Trips", trips_path, class: "hover:text-gray-700 transition-colors" %>
    <span>/</span>
    <%= link_to @trip.title, trip_path(@trip), class: "hover:text-gray-700 transition-colors truncate max-w-xs" %>
    <span>/</span>
    <span class="text-gray-600">Modifier</span>
  </div>

  <div class="mb-7">
    <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Modifier le trip</h1>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6">
    <%= render "form", trip: @trip %>
  </div>
</div>
