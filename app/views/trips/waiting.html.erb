<% content_for :title, "Calcul en cours… — Get Together" %>
<% content_for :nav_crumb, "Calcul en cours…" %>

<div class="max-w-[640px] mx-auto px-8 pt-20 pb-20 text-center"
     data-controller="optimization-poll"
     data-optimization-poll-url-value="<%= optimization_status_trip_path(@trip) %>"
     data-optimization-poll-results-url-value="<%= results_trip_path(@trip) %>"
     data-optimization-poll-trip-url-value="<%= trip_path(@trip) %>">

  <%# ── Animated Globe ── %>
  <div class="flex justify-center mb-8">
    <div class="relative inline-block" style="width:220px;height:220px;">
      <svg viewBox="0 0 200 200" width="220" height="220" style="overflow:visible;">
        <defs>
          <clipPath id="wglobe">
            <circle cx="100" cy="100" r="78"/>
          </clipPath>
          <g id="wcts">
            <path d="M14 52C22 44 34 42 46 44C56 42 66 46 74 50L82 54C80 60 72 62 66 64C70 70 68 76 62 80C58 86 52 90 48 94C46 100 50 104 48 108C44 110 40 106 38 100C34 94 36 86 32 80C26 74 22 66 18 60Z"/>
            <path d="M72 36C80 34 86 38 84 46C80 50 74 48 72 44Z"/>
            <path d="M54 112C62 110 70 114 72 122C74 130 68 138 66 146C62 152 58 156 54 152C52 146 54 138 52 132C50 124 50 118 54 112Z"/>
            <path d="M98 50C108 46 120 48 130 50C140 48 150 52 156 56C154 62 146 62 140 60C136 64 128 64 122 60C116 62 108 62 102 58Z"/>
            <path d="M108 72C120 68 134 70 142 76C148 82 146 92 142 100C140 110 134 120 128 128C122 134 116 130 114 122C110 114 108 104 106 94C104 86 104 78 108 72Z"/>
            <path d="M156 48C170 44 186 48 196 54L200 58C200 66 192 68 184 66C178 72 170 74 162 70C158 66 154 60 156 54Z"/>
            <path d="M0 158C20 154 44 160 68 156C92 160 118 154 142 158C166 156 186 160 200 158L200 172L0 172Z"/>
          </g>
        </defs>

        <%# Equatorial ring (pulsing) %>
        <ellipse cx="100" cy="100" rx="94" ry="36" fill="none" stroke="#2D4A3E" stroke-width="1.25"
          style="transform-origin:100px 100px;transform:rotate(-15deg);animation:gt-pulse 3.2s ease-in-out infinite;"/>

        <g style="transform-origin:100px 100px;transform:rotate(-15deg);">
          <circle cx="100" cy="100" r="78" fill="#FFFFFF" stroke="#2D4A3E" stroke-width="1.75"/>
          <g clip-path="url(#wglobe)">
            <%# Lat/lon lines — static %>
            <g fill="none" stroke="#2D4A3E" stroke-width="0.9" opacity="0.5">
              <line x1="22" y1="100" x2="178" y2="100"/>
              <ellipse cx="100" cy="100" rx="78" ry="26"/>
              <ellipse cx="100" cy="100" rx="78" ry="52"/>
            </g>
            <%# Meridians — spinning %>
            <g fill="none" stroke="#2D4A3E" stroke-width="0.9" opacity="0.5"
               style="transform-origin:100px 100px;animation:gt-spin 8s linear infinite;">
              <ellipse cx="100" cy="100" rx="26" ry="78"/>
              <ellipse cx="100" cy="100" rx="52" ry="78"/>
              <line x1="100" y1="22" x2="100" y2="178"/>
            </g>
            <%# Continents — drifting %>
            <g fill="#2D4A3E" style="animation:gt-drift 8s linear infinite;">
              <use href="#wcts" x="0" y="0"/>
              <use href="#wcts" x="200" y="0"/>
            </g>
          </g>
          <circle cx="100" cy="100" r="78" fill="none" stroke="#2D4A3E" stroke-width="1.75"/>
        </g>
      </svg>
    </div>
  </div>

  <%# ── Kicker ── %>
  <div class="font-mono text-[11px] tracking-[0.13em] uppercase text-gt-muted mb-3">Calcul des prix · Duffel</div>

  <%# ── Headline ── %>
  <h1 class="font-display font-normal text-[48px] leading-[1.05] tracking-[-0.025em] text-gt-forest mb-4 sm:text-[32px]">
    On sillonne les cieux pour <em class="italic text-gt-orange">la réponse honnête…</em>
  </h1>

  <p class="text-[16px] text-gt-ink-soft leading-relaxed max-w-[440px] mx-auto mb-8">
    On interroge Duffel pour les vrais tarifs depuis chaque origine vers chaque destination.
  </p>

  <%# ── Progress bar ── %>
  <div class="mb-8 max-w-[400px] mx-auto">
    <div class="flex justify-between items-center mb-2">
      <span class="font-mono text-[11px] tracking-[0.06em] text-gt-muted" data-optimization-poll-target="statusText">
        Connexion aux APIs de vols…
      </span>
      <span class="font-mono text-[11px] text-gt-muted" data-optimization-poll-target="progressLabel">0%</span>
    </div>
    <div class="h-1.5 bg-gt-sand-dark rounded-full overflow-hidden">
      <div data-optimization-poll-target="progressBar"
           class="h-full bg-gt-orange rounded-full transition-all duration-700 ease-out"
           style="width: 4%">
      </div>
    </div>
  </div>

  <%# ── Route chips grid ── %>
  <div class="grid grid-cols-4 gap-2 text-left mb-10 sm:grid-cols-2" data-optimization-poll-target="steps">
    <%
      participants = @trip.participants.first(4)
      destinations = @trip.candidate_cities.any? ? @trip.candidate_cities.first(4) : [
        OpenStruct.new(city_name: "Lisbonne", airport_code: "LIS"),
        OpenStruct.new(city_name: "Dublin",   airport_code: "DUB"),
        OpenStruct.new(city_name: "Bruxelles",airport_code: "BRU"),
        OpenStruct.new(city_name: "Barcelone",airport_code: "BCN"),
      ]
      routes = participants.flat_map { |p| destinations.map { |d| [p, d] } }.first(8)
    %>
    <% routes.each_with_index do |(participant, dest), i| %>
      <div class="p-2.5 rounded-[10px] bg-gt-sand border border-dashed border-gt-line font-mono text-[10px] flex justify-between items-center"
           data-step="<%= i %>">
        <span class="text-gt-muted"><%= participant.origin_airport_code.presence || participant.origin_city[0..2].upcase %> → <%= dest.airport_code %></span>
        <span class="step-status text-gt-muted">…</span>
      </div>
    <% end %>
  </div>

  <%# ── Email capture ── %>
  <div class="max-w-[440px] mx-auto">
    <div class="bg-gt-white border border-gt-line rounded-[18px] p-6">
      <div class="font-mono text-[10px] tracking-[0.1em] uppercase text-gt-muted mb-2">Vous partez ?</div>
      <p class="text-[15px] text-gt-ink-soft mb-4 leading-relaxed">
        Recevez les résultats par email si vous fermez cette page.
      </p>
      <div id="email-form-area">
        <div class="flex gap-2 sm:flex-col">
          <input type="email" id="notify-email-input" placeholder="votre@email.com"
                 class="flex-1 px-4 py-2.5 rounded-full border border-gt-line text-[14px] text-gt-ink bg-gt-sand focus:outline-none focus:border-gt-forest/40 placeholder:text-gt-muted/60 transition-colors">
          <button type="button" onclick="submitNotifyEmail(this)"
                  data-url="<%= save_notification_email_trip_path(@trip) %>"
                  data-csrf="<%= form_authenticity_token %>"
                  class="px-5 py-2.5 rounded-full bg-gt-forest text-white text-[14px] font-medium hover:bg-gt-forest/90 transition-colors flex-shrink-0">
            M'avertir
          </button>
        </div>
        <p class="font-mono text-[10px] text-gt-muted mt-2.5 tracking-[0.04em]">Pas de spam. Un seul email quand c'est prêt.</p>
      </div>
    </div>
  </div>

</div>

<script>
  async function submitNotifyEmail(btn) {
    const input = document.getElementById('notify-email-input');
    const email = input.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      input.classList.add('border-red-300');
      input.focus();
      setTimeout(() => input.classList.remove('border-red-300'), 1500);
      return;
    }

    btn.disabled = true;
    btn.textContent = '…';

    try {
      const res = await fetch(btn.dataset.url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': btn.dataset.csrf,
          'Accept': 'application/json'
        },
        body: JSON.stringify({ notification_email: email })
      });

      if (res.ok) {
        document.getElementById('email-form-area').innerHTML = `
          <div class="flex items-center gap-2.5 justify-center py-1">
            <div class="w-6 h-6 rounded-full bg-gt-forest/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-gt-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-[14px] text-gt-forest font-medium">On vous envoie ça dès que c'est prêt.</span>
          </div>`;
      } else {
        btn.disabled = false;
        btn.textContent = "M'avertir";
        input.classList.add('border-red-300');
        setTimeout(() => input.classList.remove('border-red-300'), 1500);
      }
    } catch {
      btn.disabled = false;
      btn.textContent = "M'avertir";
    }
  }
</script>
