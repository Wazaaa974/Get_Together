<div class="w-full max-w-lg mx-auto mt-16 text-center px-4"
     data-controller="optimization-poll"
     data-optimization-poll-url-value="<%= optimization_status_trip_path(@trip) %>"
     data-optimization-poll-results-url-value="<%= results_trip_path(@trip) %>"
     data-optimization-poll-trip-url-value="<%= trip_path(@trip) %>">

  <%# Icône animée %>
  <div class="mb-8 relative inline-block">
    <div class="w-24 h-24 rounded-full bg-indigo-100 flex items-center justify-center">
      <svg class="w-12 h-12 text-indigo-600 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
    </div>
    <div class="absolute -top-1 -right-1 w-5 h-5 bg-indigo-600 rounded-full flex items-center justify-center">
      <div class="w-2 h-2 bg-white rounded-full animate-ping"></div>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-2">Recherche en cours…</h1>
  <p class="text-gray-500 text-sm mb-8 leading-relaxed">
    On interroge les APIs de vols pour<br class="hidden sm:block">
    <strong class="text-gray-700"><%= @trip.participants.count %> participant<%= @trip.participants.count > 1 ? 's' : '' %></strong>
    sur <strong class="text-gray-700">10 destinations européennes</strong>.
  </p>

  <%# Étapes de progression %>
  <div class="bg-white border border-gray-200 rounded-2xl p-5 mb-6 text-left space-y-3" data-optimization-poll-target="steps">
    <% [
      ["Connexion aux APIs de vols", true],
      ["Évaluation des destinations", false],
      ["Calcul des scores et prix", false],
      ["Classement final", false]
    ].each.with_index do |(label, done), i| %>
      <div class="flex items-center gap-3 step-item" data-step="<%= i %>">
        <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 step-icon <%= i == 0 ? 'bg-indigo-100' : 'bg-gray-100' %>">
          <% if done %>
            <svg class="w-3 h-3 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <% else %>
            <div class="w-1.5 h-1.5 rounded-full <%= i == 0 ? 'bg-indigo-400 animate-pulse' : 'bg-gray-300' %>"></div>
          <% end %>
        </div>
        <span class="text-sm <%= i == 0 ? 'text-gray-800 font-medium' : 'text-gray-400' %> step-label"><%= label %></span>
      </div>
    <% end %>
  </div>

  <p class="text-xs text-gray-400" data-optimization-poll-target="statusText">Ça prend environ 20–30 secondes…</p>
</div>
