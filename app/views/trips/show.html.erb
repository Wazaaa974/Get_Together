<%
  content_for :og_title, "#{@trip.title} — Get Together"
  content_for :og_description, "Rejoignez le trip « #{@trip.title} » et ajoutez votre ville de départ."

  status_classes = case @trip.status
    when "active"    then "bg-green-50 text-green-700 border border-green-200"
    when "completed" then "bg-gray-100 text-gray-500"
    else                  "bg-amber-50 text-amber-700 border border-amber-200"
  end
  status_label = case @trip.status
    when "active"    then "Actif"
    when "completed" then "Terminé"
    else                  "Brouillon"
  end
  ready_to_optimize = @trip.participants.any?
  is_owner = @is_owner || false
  failed   = @trip.optimization_status == "failed"
  has_results = @trip.route_quotes.any?
%>

<div class="w-full max-w-3xl mx-auto space-y-6">

  <%# Bannière vue partagée %>
  <% if @shared_view %>
    <div class="bg-indigo-50 border border-indigo-200 rounded-xl px-5 py-3 flex items-center gap-3 text-sm text-indigo-700">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      Vous consultez ce trip via un lien de partage. Ajoutez votre ville ci-dessous.
    </div>
  <% end %>

  <%# Breadcrumb (owner uniquement) %>
  <% unless @shared_view %>
    <div class="flex items-center gap-2 text-sm text-gray-400">
      <%= link_to "Mes voyages", trips_path, class: "hover:text-gray-700 transition-colors" %>
      <span>/</span>
      <span class="text-gray-600 truncate max-w-xs"><%= @trip.title %></span>
    </div>
  <% end %>

  <%# En-tête %>
  <div class="bg-white border border-gray-200 rounded-2xl p-6">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-xl font-bold text-gray-900 tracking-tight truncate"><%= @trip.title %></h1>
          <span class="text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0 <%= status_classes %>"><%= status_label %></span>
        </div>
        <% if @trip.start_date.present? %>
          <p class="text-sm text-gray-500 mt-1.5 inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <%= @trip.start_date.strftime("%d %b %Y") %>
            <% if @trip.end_date.present? %><span class="text-gray-300">→</span> <%= @trip.end_date.strftime("%d %b %Y") %><% end %>
          </p>
        <% end %>
      </div>
      <% if is_owner %>
        <div class="flex items-center gap-2 flex-shrink-0">
          <%= link_to "Modifier", edit_trip_path(@trip),
              class: "text-sm text-gray-500 border border-gray-200 px-3 py-1.5 rounded-lg hover:bg-gray-50 transition-colors" %>
          <%= button_to "Supprimer", trip_path(@trip), method: :delete,
              class: "text-sm text-red-500 border border-red-200 px-3 py-1.5 rounded-lg hover:bg-red-50 transition-colors",
              data: { turbo_confirm: "Supprimer ce trip définitivement ?" } %>
        </div>
      <% end %>
    </div>

    <%# Résultats disponibles — bannière rapide %>
    <% if has_results %>
      <div class="mt-4 bg-indigo-50 border border-indigo-200 rounded-xl px-4 py-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2.5 text-sm text-indigo-700 min-w-0">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span class="font-medium">Résultats disponibles</span>
          <span class="text-indigo-500 text-xs hidden sm:inline">Calculé récemment</span>
        </div>
        <%= link_to "Voir les résultats →", results_trip_path(@trip),
            class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800 flex-shrink-0 transition-colors" %>
      </div>
    <% end %>

    <%# Lien de partage (owner seulement) %>
    <% if is_owner && @trip.share_token.present? %>
      <div class="mt-5 pt-5 border-t border-gray-100">
        <p class="text-xs font-medium text-gray-500 mb-2">Inviter des participants</p>
        <div class="flex items-center gap-2">
          <input type="text" readonly
            value="<%= shared_trip_url(@trip.share_token) %>"
            class="flex-1 text-xs text-gray-500 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 focus:outline-none font-mono truncate"
            id="share-link-<%= @trip.id %>">
          <button type="button"
            onclick="navigator.clipboard.writeText(document.getElementById('share-link-<%= @trip.id %>').value).then(() => { this.textContent = 'Copié !'; this.classList.add('bg-green-50','text-green-700','border-green-200'); setTimeout(() => { this.textContent = 'Copier'; this.classList.remove('bg-green-50','text-green-700','border-green-200') }, 2000) })"
            class="text-xs text-indigo-600 border border-indigo-200 px-3 py-2 rounded-lg hover:bg-indigo-50 transition-colors flex-shrink-0 font-medium">
            Copier
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-1.5">Quiconque a ce lien peut rejoindre et ajouter sa ville — sans compte.</p>
      </div>
    <% end %>
  </div>

  <%# Participants %>
  <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <h2 class="font-semibold text-gray-900">Participants</h2>
        <% if @trip.participants.any? %>
          <%# Avatars empilés %>
          <div class="flex -space-x-2">
            <% @trip.participants.first(4).each do |p| %>
              <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-xs font-bold border-2 border-white flex-shrink-0" title="<%= p.name %>">
                <%= p.name[0].upcase %>
              </div>
            <% end %>
            <% if @trip.participants.count > 4 %>
              <div class="w-6 h-6 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-xs font-bold border-2 border-white">
                +<%= @trip.participants.count - 4 %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full"><%= @trip.participants.count %></span>
    </div>

    <% if @trip.participants.any? %>
      <ul class="divide-y divide-gray-50" id="participants-list">
        <% @trip.participants.each do |participant| %>
          <%= turbo_frame_tag dom_id(participant) do %>
            <li class="px-6 py-3.5 hover:bg-gray-50 transition-colors">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-xs font-semibold flex-shrink-0">
                    <%= participant.name[0].upcase %>
                  </div>
                  <div class="min-w-0">
                    <span class="font-medium text-gray-800 text-sm"><%= participant.name %></span>
                    <span class="text-gray-400 text-sm mx-1.5">·</span>
                    <span class="text-gray-500 text-sm"><%= participant.origin_city %></span>
                    <% if participant.origin_airport_code.present? %>
                      <span class="text-xs text-gray-400 ml-1 font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= participant.origin_airport_code %></span>
                    <% end %>
                  </div>
                </div>
                <% if is_owner %>
                  <div class="flex items-center gap-1 flex-shrink-0 ml-2">
                    <%= link_to edit_trip_participant_path(@trip, participant),
                        class: "text-gray-400 hover:text-indigo-500 transition-colors p-1 rounded",
                        data: { turbo_frame: dom_id(participant) } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    <% end %>
                    <%= button_to trip_participant_path(@trip, participant), method: :delete,
                        class: "text-gray-300 hover:text-red-400 transition-colors p-1 rounded",
                        data: { turbo_confirm: "Supprimer #{participant.name} ?" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </li>
          <% end %>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-8 text-center">
        <div class="inline-flex items-center justify-center w-10 h-10 bg-indigo-50 rounded-full mb-3">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <p class="text-sm font-medium text-gray-600 mb-1">Personne n'a encore rejoint</p>
        <p class="text-xs text-gray-400">Partagez le lien du trip pour inviter vos amis.</p>
      </div>
    <% end %>

    <%# Formulaire ajout participant (owner ou vue partagée) %>
    <% if is_owner || @shared_view %>
      <% form_url = @shared_view ? shared_trip_participants_path(@trip.share_token) : trip_participants_path(@trip) %>
      <%= form_with model: @new_participant, url: form_url,
          class: "px-6 py-4 bg-gray-50 border-t border-gray-100" do |f| %>
        <% if @new_participant.errors.any? %>
          <p class="text-xs text-red-600 mb-2 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <%= @new_participant.errors.full_messages.first %>
          </p>
        <% end %>
        <div class="flex gap-2 flex-wrap items-start">
          <div class="flex-1 min-w-28">
            <%= f.text_field :name, placeholder: "Prénom",
                class: "w-full border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          </div>
          <%# Autocomplete ville %>
          <div class="flex-1 min-w-40 relative"
               data-controller="city-autocomplete"
               data-action="focusout->city-autocomplete#onFocusOut">
            <%= f.text_field :origin_city, placeholder: "Ville de départ",
                class: "w-full border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                data: {
                  city_autocomplete_target: "input",
                  action: "input->city-autocomplete#onInput keydown->city-autocomplete#onKeydown"
                },
                autocomplete: "off" %>
            <ul data-city-autocomplete-target="dropdown"
                class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 overflow-hidden max-h-48 overflow-y-auto"
                data-action="click->city-autocomplete#select">
            </ul>
          </div>
          <div class="w-32">
            <%= f.text_field :origin_airport_code, placeholder: "Code aéroport (ex : CDG)",
                class: "w-full border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          </div>
          <%= f.submit "Ajouter",
              class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors cursor-pointer flex-shrink-0" %>
        </div>
        <p class="text-xs text-gray-400 mt-1.5">Le code aéroport est facultatif — il sera détecté automatiquement selon la ville.</p>
      <% end %>
    <% end %>
  </div>

  <%# Villes candidates (owner seulement) %>
  <% if is_owner %>
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h2 class="font-semibold text-gray-900">Ajouter une destination</h2>
          <p class="text-xs text-gray-400 mt-0.5">Facultatif — 10 destinations populaires sont déjà évaluées automatiquement.</p>
        </div>
        <% if @trip.candidate_cities.any? %>
          <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full"><%= @trip.candidate_cities.count %></span>
        <% end %>
      </div>

      <% if @trip.candidate_cities.any? %>
        <ul class="divide-y divide-gray-50">
          <% @trip.candidate_cities.each do |city| %>
            <li class="flex items-center justify-between px-6 py-3.5 hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-7 h-7 rounded-full bg-teal-50 text-teal-600 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                </div>
                <div>
                  <span class="font-medium text-gray-800 text-sm"><%= city.city_name %></span>
                  <% if city.country_code.present? %>
                    <span class="text-gray-400 text-xs ml-1.5 font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= city.country_code %></span>
                  <% end %>
                  <% if city.airport_code.present? %>
                    <span class="text-xs text-gray-400 ml-1 font-mono bg-gray-100 px-1.5 py-0.5 rounded"><%= city.airport_code %></span>
                  <% end %>
                </div>
              </div>
              <%= button_to trip_candidate_city_path(@trip, city), method: :delete,
                  class: "text-gray-300 hover:text-red-400 transition-colors p-1 rounded",
                  data: { turbo_confirm: "Supprimer #{city.city_name} ?" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-5 text-center">
          <p class="text-sm text-gray-400">Aucune ville ajoutée — 10 destinations populaires seront évaluées automatiquement.</p>
        </div>
      <% end %>

      <%= form_with model: [@trip, @new_candidate_city], class: "px-6 py-4 bg-gray-50 border-t border-gray-100" do |f| %>
        <% if @new_candidate_city.errors.any? %>
          <p class="text-xs text-red-600 mb-2"><%= @new_candidate_city.errors.full_messages.first %></p>
        <% end %>
        <div class="flex gap-2 flex-wrap">
          <%# Autocomplete ville candidate %>
          <div class="flex-1 min-w-32 relative"
               data-controller="city-autocomplete"
               data-action="focusout->city-autocomplete#onFocusOut">
            <%= f.text_field :city_name, placeholder: "Ville (ex : Dublin)",
                class: "w-full border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                data: {
                  city_autocomplete_target: "input",
                  action: "input->city-autocomplete#onInput keydown->city-autocomplete#onKeydown"
                },
                autocomplete: "off" %>
            <ul data-city-autocomplete-target="dropdown"
                class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 overflow-hidden max-h-48 overflow-y-auto"
                data-action="click->city-autocomplete#select">
            </ul>
          </div>
          <%= f.text_field :country_code, placeholder: "Pays (ex : IE)",
              class: "w-28 border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <%= f.text_field :airport_code, placeholder: "IATA (ex : DUB)",
              class: "w-36 border border-gray-300 bg-white rounded-lg px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <%= f.submit "Ajouter",
              class: "bg-white border border-indigo-200 text-indigo-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-50 transition-colors cursor-pointer flex-shrink-0" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Zone calcul (owner seulement) %>
  <% if is_owner %>
    <% if failed %>
      <div class="bg-red-50 border border-red-200 rounded-2xl p-6 flex items-start gap-4">
        <div class="w-9 h-9 rounded-xl bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-red-800 text-sm">Le calcul a échoué</p>
          <p class="text-xs text-red-600 mt-1">L'API de vols n'a pas répondu correctement. Vérifiez les villes des participants (noms complets de préférence) et réessayez.</p>
        </div>
        <%= button_to "Réessayer →", optimize_trip_path(@trip), method: :post,
            class: "bg-red-600 hover:bg-red-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition-colors flex-shrink-0 self-center" %>
      </div>
    <% elsif ready_to_optimize %>
      <div class="bg-gradient-to-br from-indigo-600 to-indigo-700 rounded-2xl p-6 flex items-center justify-between gap-4 shadow-lg shadow-indigo-200">
        <div class="text-white">
          <p class="font-bold text-base">Prêt à trouver le meilleur endroit ?</p>
          <p class="text-indigo-200 text-sm mt-1">
            <%= @trip.participants.count %> participant<%= @trip.participants.count > 1 ? 's' : '' %> depuis
            <%= @trip.participants.map(&:origin_city).first(2).join(", ") %><%= @trip.participants.count > 2 ? " et #{@trip.participants.count - 2} autre#{@trip.participants.count - 2 > 1 ? 's' : ''}" : '' %>
          </p>
        </div>
        <%= button_to "Lancer le calcul →", optimize_trip_path(@trip), method: :post,
            class: "bg-white text-indigo-700 px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-indigo-50 transition-colors flex-shrink-0 shadow-sm" %>
      </div>
    <% else %>
      <div class="bg-gray-50 border border-dashed border-gray-300 rounded-2xl p-6 text-center">
        <div class="inline-flex items-center justify-center w-10 h-10 bg-white border border-gray-200 rounded-xl mb-3 shadow-sm">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </div>
        <p class="text-sm font-medium text-gray-600">Ajoutez des participants pour lancer le calcul</p>
        <p class="text-xs text-gray-400 mt-1">Get Together analysera les prix pour 10 destinations européennes.</p>
      </div>
    <% end %>
  <% end %>

</div>
