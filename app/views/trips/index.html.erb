<% content_for :title, "Get Together — Trouvez l'endroit idéal" %>

<% if @trips.empty? %>
  <%# Hero for empty state %>
  <div class="text-center py-20">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-2xl mb-6">
      <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 004 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Trouvez l'endroit idéal<br>pour vous retrouver</h1>
    <p class="text-gray-500 max-w-md mx-auto mb-8 leading-relaxed">
      Chaque personne indique sa ville de départ. Get Together calcule automatiquement la destination la moins chère pour tout le groupe.
    </p>
    <%= link_to "Créer mon premier trip", new_trip_path,
        class: "inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-200" %>
  </div>
<% else %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Mes trips</h1>
      <p class="text-gray-500 text-sm mt-0.5"><%= @trips.count %> trip<%= @trips.count > 1 ? "s" : "" %> en cours</p>
    </div>
    <%= link_to new_trip_path,
        class: "inline-flex items-center gap-2 bg-indigo-600 text-white px-4 py-2 rounded-xl font-medium text-sm hover:bg-indigo-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nouveau trip
    <% end %>
  </div>

  <div class="space-y-3">
    <% @trips.each do |trip| %>
      <%
        status_classes = case trip.status
          when "active"    then "bg-emerald-50 text-emerald-700 border border-emerald-200"
          when "completed" then "bg-gray-100 text-gray-500"
          else                  "bg-amber-50 text-amber-700 border border-amber-200"
        end
        status_label = case trip.status
          when "active"    then "Actif"
          when "completed" then "Terminé"
          else                  "Brouillon"
        end
      %>
      <div class="bg-white border border-gray-100 rounded-2xl p-5 hover:border-indigo-200 hover:shadow-sm transition-all">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-2.5 flex-wrap mb-1.5">
              <h2 class="font-semibold text-gray-900 text-base truncate"><%= trip.title %></h2>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium flex-shrink-0 <%= status_classes %>"><%= status_label %></span>
            </div>
            <div class="flex items-center gap-4 text-sm text-gray-500 flex-wrap">
              <% if trip.start_date.present? %>
                <span class="inline-flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <%= trip.start_date.strftime("%d %b %Y") %>
                  <% if trip.end_date.present? %><span class="text-gray-300">→</span> <%= trip.end_date.strftime("%d %b %Y") %><% end %>
                </span>
              <% end %>
              <span class="inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <%= trip.participants.count %> participant<%= trip.participants.count > 1 ? "s" : "" %>
              </span>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <% if trip.route_quotes.any? %>
              <%= link_to "Voir résultats", results_trip_path(trip),
                  class: "text-sm bg-indigo-50 text-indigo-600 border border-indigo-200 px-3 py-1.5 rounded-lg font-medium hover:bg-indigo-100 transition-colors" %>
            <% end %>
            <%= link_to "→", trip_path(trip),
                class: "w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors font-medium" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
