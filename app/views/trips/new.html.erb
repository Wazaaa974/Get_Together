<% content_for :title, "Nouveau trip — Get Together" %>
<% content_for :nav_crumb, "Nouveau trip" %>

<div class="max-w-[960px] mx-auto px-4 sm:px-6 lg:px-8 pt-[73px] lg:pt-[81px] pb-20">

  <%# ── Header row ── %>
  <div class="flex items-start justify-between mb-6 sm:mb-8 gap-3">
    <div class="min-w-0">
      <div class="font-mono text-[11px] tracking-[0.12em] uppercase text-gt-muted mb-2">Étape 1 / 2 — Votre groupe</div>
      <h1 class="font-display font-normal text-[32px] sm:text-[44px] lg:text-[56px] leading-[1.05] tracking-[-0.025em] text-gt-forest">
        Qui se <em class="italic text-gt-orange">retrouve&nbsp;?</em>
      </h1>
    </div>
    <div class="flex-shrink-0 mt-2" style="transform: rotate(-6deg);" aria-hidden="true">
      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-dashed border-gt-forest text-gt-forest rounded font-mono text-[10px] font-medium tracking-[0.12em] uppercase">Brouillon</div>
    </div>
  </div>

  <%= form_with model: @trip, class: "" do |f| %>
    <% if @trip.errors.any? %>
      <div class="mb-5 bg-red-50 border border-red-200 rounded-[14px] p-4">
        <p class="text-sm font-medium text-red-800 mb-1">Impossible de sauvegarder :</p>
        <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
          <% @trip.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :status, value: "draft" %>

    <div class="grid gap-5 grid-cols-1 lg:[grid-template-columns:1.2fr_1fr]">

      <%# ── LEFT ── %>
      <div class="flex flex-col gap-5">

        <%# Trip name card %>
        <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]"
             data-controller="title-presets">
          <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted mb-3.5">Nom du trip</div>
          <%= f.text_field :title,
              placeholder: "Eurotrip avec la promo…",
              data: { title_presets_target: "input" },
              class: "w-full pb-3 border-b border-gt-line bg-transparent font-display text-[20px] sm:text-[26px] text-gt-forest tracking-[-0.01em] focus:outline-none focus:border-gt-orange transition-colors placeholder:text-gt-muted/50" %>
          <div class="flex gap-2 flex-wrap mt-4">
            <% ["Week-end entre amis", "Réunion de famille", "Retraite d'équipe", "Anniversaire"].each do |preset| %>
              <button type="button"
                data-action="title-presets#apply"
                data-value="<%= preset %>"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gt-white border border-gt-line text-gt-forest text-xs font-medium hover:border-gt-forest/30 transition-colors cursor-pointer">
                <%= preset %>
              </button>
            <% end %>
          </div>
        </div>

        <%# Participants — ajout inline %>
        <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]"
             data-controller="participant-rows">

          <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted mb-3.5">Participants</div>

          <%# Rows container %>
          <div class="flex flex-col gap-2" data-participant-rows-target="container">
            <%= f.fields_for :participants do |pf| %>
              <div data-participant-row class="flex items-center gap-2 bg-gt-sand rounded-[12px] px-3 py-2.5 border border-gt-line">
                <div class="w-8 h-8 rounded-full bg-gt-orange-light flex items-center justify-center font-display italic text-gt-orange text-[16px] flex-shrink-0">g</div>
                <div class="flex-1 min-w-0">
                  <%= pf.text_field :name, placeholder: "Prénom",
                      class: "w-full border-none bg-transparent outline-none text-[14px] text-gt-ink placeholder:text-gt-muted" %>
                </div>
                <div class="w-px h-5 bg-gt-line flex-shrink-0"></div>
                <div class="flex-[1.8] min-w-0 relative"
                     data-controller="city-autocomplete"
                     data-action="focusout->city-autocomplete#onFocusOut">
                  <%= pf.text_field :origin_city, placeholder: "Ville de départ",
                      class: "w-full border-none bg-transparent outline-none text-[14px] text-gt-ink placeholder:text-gt-muted",
                      data: { city_autocomplete_target: "input", action: "input->city-autocomplete#onInput keydown->city-autocomplete#onKeydown" },
                      autocomplete: "off" %>
                  <ul data-city-autocomplete-target="dropdown"
                      class="hidden absolute top-full left-0 right-0 mt-1 bg-gt-white border border-gt-line rounded-[14px] z-20 overflow-hidden max-h-48 overflow-y-auto"
                      data-action="click->city-autocomplete#select"></ul>
                </div>
                <button type="button"
                        data-action="participant-rows#remove"
                        class="text-gt-muted hover:text-red-400 transition-colors flex-shrink-0 p-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
            <% end %>
          </div>

          <%# Template for JS-added rows %>
          <template data-participant-rows-target="template">
            <div data-participant-row class="flex items-center gap-2 bg-gt-sand rounded-[12px] px-3 py-2.5 border border-gt-line">
              <div class="w-8 h-8 rounded-full bg-gt-orange-light flex items-center justify-center font-display italic text-gt-orange text-[16px] flex-shrink-0">g</div>
              <div class="flex-1 min-w-0">
                <input type="text" name="trip[participants_attributes][NEW_IDX][name]" placeholder="Prénom"
                       class="w-full border-none bg-transparent outline-none text-[14px] text-gt-ink placeholder:text-gt-muted">
              </div>
              <div class="w-px h-5 bg-gt-line flex-shrink-0"></div>
              <div class="flex-[1.8] min-w-0 relative"
                   data-controller="city-autocomplete"
                   data-action="focusout->city-autocomplete#onFocusOut">
                <input type="text" name="trip[participants_attributes][NEW_IDX][origin_city]" placeholder="Ville de départ"
                       autocomplete="off"
                       class="w-full border-none bg-transparent outline-none text-[14px] text-gt-ink placeholder:text-gt-muted"
                       data-city-autocomplete-target="input"
                       data-action="input->city-autocomplete#onInput keydown->city-autocomplete#onKeydown">
                <ul data-city-autocomplete-target="dropdown"
                    class="hidden absolute top-full left-0 right-0 mt-1 bg-gt-white border border-gt-line rounded-[14px] z-20 overflow-hidden max-h-48 overflow-y-auto"
                    data-action="click->city-autocomplete#select"></ul>
              </div>
              <button type="button"
                      data-action="participant-rows#remove"
                      class="text-gt-muted hover:text-red-400 transition-colors flex-shrink-0 p-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          </template>

          <%# Add row button %>
          <button type="button"
                  data-action="participant-rows#add"
                  class="mt-2.5 w-full flex items-center justify-center gap-2 px-3 py-2.5 rounded-[12px] border border-dashed border-gt-line text-gt-muted hover:border-gt-orange hover:text-gt-orange transition-colors text-[13px] font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter un participant
          </button>

          <p class="font-mono text-[10px] tracking-[0.06em] text-gt-muted mt-2.5">CODE AÉROPORT FACULTATIF — DÉTECTÉ AUTOMATIQUEMENT</p>
        </div>

      </div>

      <%# ── RIGHT ── %>
      <div class="flex flex-col gap-5">

        <%# Dates card %>
        <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]"
             data-controller="date-presets">
          <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted mb-3.5">Quand</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="p-3.5 border border-gt-line rounded-[12px] bg-gt-sand">
              <div class="font-mono text-[10px] tracking-[0.08em] uppercase text-gt-muted mb-1.5">Départ</div>
              <%= f.date_field :start_date,
                  data: { date_presets_target: "start" },
                  class: "w-full border-none bg-transparent font-display text-[18px] sm:text-[20px] text-gt-forest focus:outline-none cursor-pointer" %>
            </div>
            <div class="p-3.5 border border-gt-line rounded-[12px] bg-gt-sand">
              <div class="font-mono text-[10px] tracking-[0.08em] uppercase text-gt-muted mb-1.5">Retour</div>
              <%= f.date_field :end_date,
                  data: { date_presets_target: "end" },
                  class: "w-full border-none bg-transparent font-display text-[18px] sm:text-[20px] text-gt-forest focus:outline-none cursor-pointer" %>
            </div>
          </div>
          <div class="flex gap-2 flex-wrap mt-3">
            <button type="button"
                    data-action="date-presets#weekend"
                    class="inline-flex items-center px-3 py-1.5 rounded-full bg-gt-sand-dark text-gt-ink-soft text-xs font-medium hover:bg-gt-orange-light hover:text-gt-orange-dark transition-colors cursor-pointer">
              Ce week-end
            </button>
            <button type="button"
                    data-action="date-presets#nextMonth"
                    class="inline-flex items-center px-3 py-1.5 rounded-full bg-gt-sand-dark text-gt-ink-soft text-xs font-medium hover:bg-gt-orange-light hover:text-gt-orange-dark transition-colors cursor-pointer">
              Le mois prochain
            </button>
          </div>
        </div>

        <%# Candidate cities preview card %>
        <div class="bg-gt-white border border-gt-line rounded-[18px] p-4 sm:p-[22px]">
          <div class="flex items-baseline justify-between mb-3.5 gap-2 flex-wrap">
            <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted">Destinations cibles</div>
            <span class="text-xs text-gt-muted">Évaluées automatiquement</span>
          </div>
          <% [["Lisbonne","PT"], ["Dublin","IE"], ["Bruxelles","BE"], ["Barcelone","ES"], ["Amsterdam","NL"]].each_with_index do |(c, cc), i| %>
            <div class="flex items-center gap-3 py-2.5 <%= i < 4 ? 'border-b border-dashed border-gt-line' : '' %>">
              <div class="w-8 h-8 rounded-[10px] bg-gt-sand flex items-center justify-center font-mono text-[10px] text-gt-forest tracking-[0.06em] flex-shrink-0"><%= cc %></div>
              <span class="text-[14px] text-gt-ink-soft flex-1"><%= c %></span>
              <span class="font-mono text-[11px] text-gt-muted opacity-50">—</span>
            </div>
          <% end %>
          <p class="font-mono text-[10px] tracking-[0.06em] text-gt-muted mt-3">+ 5 AUTRES DESTINATIONS POPULAIRES</p>
        </div>

      </div>

    </div>

    <%# ── Bottom bar ── %>
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between mt-7 pt-5 border-t border-gt-line gap-4">
      <p class="text-[13px] text-gt-muted">En continuant, nous récupérerons les vrais tarifs via Duffel.</p>
      <div class="flex items-center gap-3 flex-wrap">
        <%= link_to "Annuler", trips_path,
            class: "px-[18px] py-3 rounded-full border border-gt-line text-gt-ink-soft text-sm font-medium hover:border-gt-forest/30 transition-colors" %>
        <%= f.submit "Trouver la ville idéale →",
            class: "px-[22px] py-[14px] rounded-full bg-gt-orange text-white text-[15px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors cursor-pointer flex-1 sm:flex-none",
            data: { disable_with: "Création…" } %>
      </div>
    </div>

  <% end %>

</div>
