<% content_for :title, "Créer un compte — Get Together" %>

<div class="max-w-sm mx-auto mt-10">

  <%# Logo + titre %>
  <div class="text-center mb-7">
    <div class="w-11 h-11 bg-gt-orange rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
    </div>
    <h1 class="text-[20px] font-medium text-gt-forest">Créer un compte</h1>
    <p class="text-[13px] text-gt-muted mt-1">Pour organiser et retrouver vos trips</p>
  </div>

  <div class="bg-gt-white border border-gray-100 rounded-[14px] p-6">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-3">
        <div>
          <%= f.label :email, "Email", class: "block text-[13px] font-medium text-gt-forest mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-200 rounded-[8px] px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition-colors bg-white" %>
        </div>

        <div>
          <%= f.label :password, "Mot de passe", class: "block text-[13px] font-medium text-gt-forest mb-1.5" %>
          <% if @minimum_password_length %>
            <p class="text-[11px] text-gt-muted mb-1"><%= @minimum_password_length %> caractères minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full border border-gray-200 rounded-[8px] px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition-colors bg-white" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-[13px] font-medium text-gt-forest mb-1.5" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full border border-gray-200 rounded-[8px] px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition-colors bg-white" %>
        </div>

        <%= f.submit "Créer mon compte",
            class: "w-full bg-gt-orange text-white py-2.5 px-4 rounded-[8px] font-medium text-sm hover:bg-gt-orange-dark transition-colors cursor-pointer mt-2" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-[13px] text-gt-muted mt-5">
    Déjà un compte ?
    <%= link_to "Se connecter", new_user_session_path, class: "text-gt-orange font-medium hover:text-gt-orange-dark" %>
  </p>

</div>
