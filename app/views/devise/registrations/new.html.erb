<% content_for :title, "Créer un compte — Get Together" %>

<div class="max-w-sm mx-auto pt-[100px] pb-20">
  <div class="text-center mb-8">
    <div class="w-12 h-12 rounded-full bg-gt-orange flex items-center justify-center font-display italic text-[28px] text-white mx-auto mb-5">g</div>
    <h1 class="font-display font-normal text-[36px] tracking-[-0.02em] text-gt-forest leading-none">Créer un compte</h1>
    <p class="text-[14px] text-gt-muted mt-2">Pour retrouver vos trips sur tous vos appareils</p>
  </div>

  <div class="bg-gt-white border border-gt-line rounded-[18px] p-6">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="space-y-4">
        <div>
          <label class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted block mb-2">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gt-line rounded-[8px] px-3.5 py-2.5 text-sm text-gt-ink bg-gt-white focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition" %>
        </div>
        <div>
          <label class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted block mb-2">Mot de passe<% if @minimum_password_length %> · <%= @minimum_password_length %> car. min<% end %></label>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full border border-gt-line rounded-[8px] px-3.5 py-2.5 text-sm text-gt-ink bg-gt-white focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition" %>
        </div>
        <div>
          <label class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted block mb-2">Confirmer</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full border border-gt-line rounded-[8px] px-3.5 py-2.5 text-sm text-gt-ink bg-gt-white focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition" %>
        </div>
        <%= f.submit "Créer mon compte",
            class: "w-full px-[22px] py-[14px] rounded-full bg-gt-orange text-white text-[15px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors cursor-pointer mt-1" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-[13px] text-gt-muted mt-5">
    Déjà un compte ?
    <%= link_to "Se connecter", new_user_session_path, class: "text-gt-orange font-medium hover:text-gt-orange-dark" %>
  </p>
</div>
