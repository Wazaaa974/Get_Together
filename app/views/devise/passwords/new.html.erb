<% content_for :title, "Mot de passe oublié — Get Together" %>

<div class="max-w-sm mx-auto mt-12">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Mot de passe oublié ?</h1>
    <p class="text-gray-500 text-sm mt-1">Entrez votre email, on vous envoie un lien de réinitialisation.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-2xl p-7 shadow-sm">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <%= f.submit "Envoyer les instructions",
            class: "w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg font-medium text-sm hover:bg-indigo-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-sm text-gray-500 mt-5">
    <%= link_to "Retour à la connexion", new_user_session_path, class: "text-indigo-600 font-medium hover:text-indigo-700" %>
  </p>
</div>
