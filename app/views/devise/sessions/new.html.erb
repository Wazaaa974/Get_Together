<% content_for :title, "Connexion — Get Together" %>

<div class="max-w-sm mx-auto mt-10">

  <%# Logo + titre %>
  <div class="text-center mb-7">
    <div class="w-11 h-11 bg-gt-orange rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
    </div>
    <h1 class="text-[20px] font-medium text-gt-forest">Bon retour</h1>
    <p class="text-[13px] text-gt-muted mt-1">Connectez-vous pour accéder à vos trips</p>
  </div>

  <div class="bg-gt-white border border-gray-100 rounded-[14px] p-6">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-3">
        <div>
          <%= f.label :email, "Email", class: "block text-[13px] font-medium text-gt-forest mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-200 rounded-[8px] px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition-colors bg-white" %>
        </div>

        <div>
          <%= f.label :password, "Mot de passe", class: "block text-[13px] font-medium text-gt-forest mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gray-200 rounded-[8px] px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition-colors bg-white" %>
        </div>

        <div class="flex items-center justify-between pt-1">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-[13px] text-gt-muted cursor-pointer">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-gt-orange focus:ring-gt-orange/20" %>
              Se souvenir de moi
            </label>
          <% end %>
          <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Mot de passe oublié ?", new_password_path(resource_name),
                class: "text-[13px] text-gt-orange hover:text-gt-orange-dark ml-auto" %>
          <% end %>
        </div>

        <%= f.submit "Se connecter",
            class: "w-full bg-gt-orange text-white py-2.5 px-4 rounded-[8px] font-medium text-sm hover:bg-gt-orange-dark transition-colors cursor-pointer mt-2" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-[13px] text-gt-muted mt-5">
    Pas encore de compte ?
    <%= link_to "Créer un compte", new_user_registration_path, class: "text-gt-orange font-medium hover:text-gt-orange-dark" %>
  </p>

</div>
