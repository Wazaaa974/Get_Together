<% content_for :title, "Connexion — Get Together" %>

<div class="max-w-sm mx-auto mt-12">
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-12 h-12 bg-indigo-600 rounded-2xl mb-4">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-gray-900">Bon retour</h1>
    <p class="text-gray-500 text-sm mt-1">Connectez-vous pour accéder à vos trips</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-2xl p-7 shadow-sm">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div>
          <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-sm text-gray-600">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
              Se souvenir de moi
            </label>
          <% end %>
          <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Mot de passe oublié ?", new_password_path(resource_name),
                class: "text-sm text-indigo-600 hover:text-indigo-700 ml-auto" %>
          <% end %>
        </div>

        <%= f.submit "Se connecter",
            class: "w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg font-medium text-sm hover:bg-indigo-700 transition-colors cursor-pointer mt-2" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-sm text-gray-500 mt-5">
    Pas encore de compte ?
    <%= link_to "Créer un compte", new_user_registration_path, class: "text-indigo-600 font-medium hover:text-indigo-700" %>
  </p>
</div>
