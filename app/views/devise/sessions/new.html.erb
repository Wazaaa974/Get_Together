<% content_for :title, "Connexion — Get Together" %>

<div class="max-w-sm mx-auto pt-[100px] pb-20">
  <div class="text-center mb-8">
    <div class="w-12 h-12 rounded-full bg-gt-orange flex items-center justify-center font-display italic text-[28px] text-white mx-auto mb-5">g</div>
    <h1 class="font-display font-normal text-[36px] tracking-[-0.02em] text-gt-forest leading-none">Bon retour</h1>
    <p class="text-[14px] text-gt-muted mt-2">Connectez-vous pour accéder à vos trips</p>
  </div>

  <div class="bg-gt-white border border-gt-line rounded-[18px] p-6">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <label class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted block mb-2">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gt-line rounded-[8px] px-3.5 py-2.5 text-sm text-gt-ink bg-gt-white focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition" %>
        </div>
        <div>
          <label class="font-mono text-[11px] tracking-[0.1em] uppercase text-gt-muted block mb-2">Mot de passe</label>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gt-line rounded-[8px] px-3.5 py-2.5 text-sm text-gt-ink bg-gt-white focus:outline-none focus:ring-2 focus:ring-gt-orange/20 focus:border-gt-orange transition" %>
        </div>
        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-[13px] text-gt-muted cursor-pointer">
              <%= f.check_box :remember_me, class: "rounded border-gt-line text-gt-orange focus:ring-gt-orange/20" %>
              Se souvenir de moi
            </label>
          <% end %>
          <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "text-[13px] text-gt-orange hover:text-gt-orange-dark ml-auto" %>
          <% end %>
        </div>
        <%= f.submit "Se connecter",
            class: "w-full px-[22px] py-[14px] rounded-full bg-gt-orange text-white text-[15px] font-medium shadow-[0_8px_24px_rgba(232,99,42,0.2)] hover:bg-gt-orange-dark transition-colors cursor-pointer mt-1" %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-[13px] text-gt-muted mt-5">
    Pas encore de compte ?
    <%= link_to "Créer un compte", new_user_registration_path, class: "text-gt-orange font-medium hover:text-gt-orange-dark" %>
  </p>
</div>
